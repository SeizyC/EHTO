{
  "name": "ehto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development next dev",
    "dev:clean": "rm -rf .next && NODE_ENV=development next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "test:regression": "node scripts/regression-ambient.mjs",
    "smoke": "node scripts/smoke-prod.mjs",
    "analyze:logs": "node scripts/analyze-logs.mjs",
    "analyze:news": "node scripts/analyze-news-citations.mjs",
    "test:energy": "tsx scripts/test-energy.ts",
    "beta:energy": "node scripts/beta-energy.mjs",
    "deploy": "npm run test:regression && opennextjs-cloudflare build && opennextjs-cloudflare deploy && npm run smoke"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@opennextjs/cloudflare": "~1.5.1",
    "@supabase/supabase-js": "^2.106.0",
    "framer-motion": "^11.11.17",
    "next": "14.2.33",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.2.3",
    "wrangler": "^4.93.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.33",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "//browserslist": "Modern targets so Next doesn't ship legacy polyfills (Array.at/flat/flatMap, Object.fromEntries/hasOwn, String.trimStart/End). All listed browsers support these natively.",
  "browserslist": [
    "chrome >= 100",
    "edge >= 100",
    "firefox >= 100",
    "safari >= 15.4",
    "ios_saf >= 15.4",
    "not dead"
  ]
}
